FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///baia360.db
# SEED_KEY e ADMIN_SENHA são um par: nunca configure ADMIN_SENHA sem também
# configurar SEED_KEY. Sem SEED_KEY, `os.getenv('SEED_KEY', '')` é '' — uma
# requisição que manda {"seed_key": ""} (string vazia, não omitida) passa no
# comparador de POST /api/auth/seed. Hoje isso fica inofensivo só porque
# ADMIN_SENHA também vazio faz a rota falhar (500) um passo depois — não
# dependa disso.
SEED_KEY=your-seed-key-here
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SENHA=your-admin-password-here

# Identidade (ver backend/identity.py) — RS256, par de chaves assimétrico.
# Gerar com:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# _carregar_chave() em identity.py aceita três formatos: PEM cru (com quebras
# de linha reais), PEM com \n escapado numa linha só, ou base64 do PEM —
# ESTE é o formato recomendado/usado em produção, porque o parser de
# multi-linha do `env_file:` do Docker Compose não é confiável para um valor
# com quebras de linha reais. Gerar a versão base64: `base64 -i private.pem`
# (ou `-w0` no Linux para não quebrar linha). Nunca commitar os arquivos .pem.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nyour-public-key-here\n-----END PUBLIC KEY-----"
# DOTENV_OVERRIDE=1 faz o .env local vencer env vars já setadas no processo —
# comportamento de dev (default é 0/ausente = seguro para produção, onde
# env_file: já injeta os segredos reais e um .env não deve conseguir
# sobrescrevê-los). O docker-compose.yml de dev já seta isso; para rodar
# `python app.py` fora do Docker, exporte DOTENV_OVERRIDE=1 você mesmo se
# precisar que o .env local vença variáveis de shell pré-existentes.
DOTENV_OVERRIDE=1

# Credencial de serviço que identifica o backend Atlas para os endpoints
# internos da Central (/internal/relatorios/*). Gerar com: openssl rand -hex 32
CENTRAL_SERVICE_TOKEN=your-central-service-token-here

# Fase 5: onde o processo Central (central_app.py) está escutando. Default
# (sem esta variável) é http://localhost:5003, para dev local rodando os
# dois processos separadamente. Em produção (docker-compose.prod.yml) o
# serviço "central" define isso como http://central:5003 via DNS do Docker.
CENTRAL_BASE_URL=http://localhost:5003

# Atlas — política de egresso para ações side-effectful (enviar_email, teams_chat_enviar).
# Lista de domínios internos separados por vírgula. Se vazio, todo destinatário é
# tratado como externo (gera aviso ⚠️ no card de confirmação).
ATLAS_EGRESSO_DOMINIOS_INTERNOS=yourdomain.com
# Se true, destinatários externos são bloqueados (403) em vez de apenas avisados.
# Default false: o gate de confirmação humana já exige aprovação explícita do usuário.
ATLAS_BLOQUEAR_EXTERNO=false