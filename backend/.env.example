FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
DATABASE_URL=sqlite:///baia360.db
SEED_KEY=your-seed-key-here
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SENHA=your-admin-password-here

# Atlas — política de egresso para ações side-effectful (enviar_email, teams_chat_enviar).
# Lista de domínios internos separados por vírgula. Se vazio, todo destinatário é
# tratado como externo (gera aviso ⚠️ no card de confirmação).
ATLAS_EGRESSO_DOMINIOS_INTERNOS=yourdomain.com
# Se true, destinatários externos são bloqueados (403) em vez de apenas avisados.
# Default false: o gate de confirmação humana já exige aprovação explícita do usuário.
ATLAS_BLOQUEAR_EXTERNO=false