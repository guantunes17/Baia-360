FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///baia360.db
SEED_KEY=your-seed-key-here
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SENHA=your-admin-password-here

# Identidade (ver backend/identity.py) — RS256, par de chaves assimétrico.
# Gerar com:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Colar o conteúdo de cada .pem inteiro (com as linhas -----BEGIN/END-----)
# na variável correspondente. Nunca commitar os arquivos .pem em si.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nyour-public-key-here\n-----END PUBLIC KEY-----"

# Credencial de serviço que identifica o backend Atlas para os endpoints
# internos da Central (/internal/relatorios/*). Gerar com: openssl rand -hex 32
CENTRAL_SERVICE_TOKEN=your-central-service-token-here

# Fase 5: onde o processo Central (central_app.py) está escutando. Default
# (sem esta variável) é http://localhost:5003, para dev local rodando os
# dois processos separadamente. Em produção (docker-compose.prod.yml) o
# serviço "central" define isso como http://central:5003 via DNS do Docker.
CENTRAL_BASE_URL=http://localhost:5003

# Atlas — política de egresso para ações side-effectful (enviar_email, teams_chat_enviar).
# Lista de domínios internos separados por vírgula. Se vazio, todo destinatário é
# tratado como externo (gera aviso ⚠️ no card de confirmação).
ATLAS_EGRESSO_DOMINIOS_INTERNOS=yourdomain.com
# Se true, destinatários externos são bloqueados (403) em vez de apenas avisados.
# Default false: o gate de confirmação humana já exige aprovação explícita do usuário.
ATLAS_BLOQUEAR_EXTERNO=false