FLASK_ENV=development
DATABASE_URL=sqlite:///baia360.db

# Fase 5 — Central só valida tokens, nunca minta: NENHUMA chave privada aqui,
# só a pública (ver backend/identity.py — configurar_jwt() aceita rodar sem
# JWT_PRIVATE_KEY). A privada mora exclusivamente no .env do Atlas.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nyour-public-key-here\n-----END PUBLIC KEY-----"

# Mesmo valor do CENTRAL_SERVICE_TOKEN no .env do Atlas — é o segredo
# compartilhado que autentica as chamadas Atlas -> Central.
CENTRAL_SERVICE_TOKEN=your-central-service-token-here

# Mesmo valor do FRONTEND_URL do Atlas — Central recebe tráfego direto do
# navegador (via nginx) para /api/modulos e /api/dashboard.
FRONTEND_URL=https://yourdomain.com

# Não presentes aqui de propósito (Central nunca usa): SECRET_KEY,
# OPENAI_API_KEY, AZURE_*, ATLAS_*, ADMIN_EMAIL/ADMIN_SENHA/SEED_KEY.
